{
  "name": "@contora/state-core",
  "version": "0.9.5",
  "description": "Tool-agnostic Contorium workspace scan, bootstrap, and dual-mode state inputs (IDE + MCP + CLI).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ContoriumLabs/contorium.git",
    "directory": "packages/state-core"
  },
  "homepage": "https://github.com/ContoriumLabs/contorium#readme",
  "bugs": {
    "url": "https://github.com/ContoriumLabs/contorium/issues"
  },
  "keywords": [
    "contorium",
    "workspace",
    "handoff",
    "mcp",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p ./",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
