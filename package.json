{
  "name": "contorium",
  "displayName": "Contorium",
  "description": "Contorium: AI Project Intelligence Layer — capture, structure, preserve, retrieve and transfer project intelligence across IDE, MCP, and CLI.",
  "version": "1.2.6",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ContoriumLabs/contorium.git"
  },
  "homepage": "https://github.com/ContoriumLabs/contorium#readme",
  "bugs": {
    "url": "https://github.com/ContoriumLabs/contorium/issues"
  },
  "publisher": "franklee-dev",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "session",
    "context",
    "workspace",
    "restore",
    "git",
    "notes",
    "ai",
    "productivity"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:contora.sidebar",
    "onCommand:contora.configureApiKey",
    "onCommand:contora.configureLlm",
    "onCommand:contora.openLlmSettings",
    "onCommand:contora.testLlmConnection",
    "onCommand:contora.generateSemanticSummary",
    "onCommand:contora.analyzeWorkspaceIntent",
    "onCommand:contora.compressContextPreview",
    "onCommand:contora.startFreshAiSession"
  ],
  "main": "./out/extension.js",
  "bin": {
    "contorium": "./packages/cli/bin/contorium.cjs",
    "contorium-mcp": "./packages/mcp/bin/contorium-mcp.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "contora.exportAIContext",
        "title": "Contorium: Transfer Context"
      },
      {
        "command": "contora.exportFullIntelligence",
        "title": "Contorium: Transfer Intelligence"
      },
      {
        "command": "contora.smartGovernanceInject",
        "title": "Contorium: Context synthesis (cognition → AI)"
      },
      {
        "command": "contora.diffGovernanceInject",
        "title": "Contorium: Diff-scoped context synthesis (cognition → AI)"
      },
      {
        "command": "contora.saveStateNow",
        "title": "Contorium: Save session state now"
      },
      {
        "command": "contora.restoreSession",
        "title": "Contorium: Restore editors from saved state"
      },
      {
        "command": "contora.configureApiKey",
        "title": "Contorium: Configure LLM (Settings)"
      },
      {
        "command": "contora.generateSemanticSummary",
        "title": "Contorium: Observe workspace (AI summary)"
      },
      {
        "command": "contora.analyzeWorkspaceIntent",
        "title": "Contorium: Learn workspace intent (AI)"
      },
      {
        "command": "contora.compressContextPreview",
        "title": "Contorium: Tighten context preview (AI)"
      },
      {
        "command": "contora.startFreshAiSession",
        "title": "Contorium: Start fresh AI context session (clear session events)"
      },
      {
        "command": "contora.showDashboard",
        "title": "Contorium: Show Runtime Dashboard"
      },
      {
        "command": "contora.askContorium",
        "title": "Contorium: Ask Contorium…"
      },
      {
        "command": "contora.cilAiTest",
        "title": "Contorium: Test LLM connection"
      },
      {
        "command": "contora.openLlmSettings",
        "title": "Contorium: Open LLM settings"
      },
      {
        "command": "contora.configureLlm",
        "title": "Contorium: Configure LLM (Settings)"
      },
      {
        "command": "contora.testLlmConnection",
        "title": "Contorium: Test LLM connection"
      },
      {
        "command": "contora.cilHistory",
        "title": "Contorium: Project History…"
      },
      {
        "command": "contora.cilDecisions",
        "title": "Contorium: Decision Center…"
      },
      {
        "command": "contora.hideDashboard",
        "title": "Contorium: Hide Runtime Dashboard"
      },
      {
        "command": "contora.controlGovernance",
        "title": "Contorium: Inspect decision provenance"
      },
      {
        "command": "contora.getGovernance",
        "title": "Contorium: Inspect decision provenance"
      },
      {
        "command": "contora.controlCheck",
        "title": "Contorium: Inspect change scope"
      },
      {
        "command": "contora.checkAction",
        "title": "Contorium: Inspect change scope"
      },
      {
        "command": "contora.controlIntent",
        "title": "Contorium: Record project direction"
      },
      {
        "command": "contora.updateProjectIntent",
        "title": "Contorium: Record project direction"
      }
    ],
    "keybindings": [
      {
        "command": "contora.showDashboard",
        "key": "ctrl+shift+c",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "contora.hideDashboard",
        "key": "ctrl+shift+m",
        "when": "workspaceFolderCount > 0"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "contora",
          "title": "Contorium",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "contora": [
        {
          "type": "webview",
          "id": "contora.sidebar",
          "name": "Contorium"
        }
      ]
    },
    "configuration": {
      "title": "Contorium",
      "properties": {
        "contora.aiProvider": {
          "type": "string",
          "order": 1,
          "enum": [
            "off",
            "openai",
            "anthropic",
            "google",
            "deepseek"
          ],
          "default": "deepseek",
          "description": "Step 1 — LLM provider. Sidebar \"Configure LLM\" opens this panel."
        },
        "contora.llmApiKey": {
          "type": "string",
          "order": 2,
          "default": "",
          "markdownDescription": "Step 2 — Paste API key for the selected provider. Saved to SecretStorage on change (field clears after save). Step 3 — enable **contora.llmTestConnection** to test."
        },
        "contora.llmTestConnection": {
          "type": "boolean",
          "order": 3,
          "default": false,
          "description": "Step 3 — Check and save to test the LLM connection (auto-resets). Or run command \"Contorium: Test LLM connection\"."
        },
        "contora.autoTestLlmOnKeySave": {
          "type": "boolean",
          "order": 4,
          "default": true,
          "description": "When contora.llmApiKey is saved, automatically run a connection test."
        },
        "contora.cilAiEnabled": {
          "type": "boolean",
          "order": 5,
          "default": false,
          "description": "Enable CIL explanation-layer LLM (Why / Story / Essence / DNA). Requires provider + API key."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node scripts/vscode-prepublish.cjs",
    "vsix": "node scripts/package-vsix.cjs",
    "validate:plugin": "node scripts/validate-plugin.mjs",
    "version:sync": "node scripts/sync-version.mjs",
    "build:runtime": "node scripts/clean-dist.mjs packages/runtime && node scripts/run-tsc.mjs packages/runtime",
    "build:state-core": "node scripts/clean-dist.mjs packages/state-core && node scripts/run-tsc.mjs packages/state-core",
    "install:cli": "node scripts/npm-install-prefix.mjs packages/cli --no-fund --no-audit",
    "build:cli": "npm run install:cli && node scripts/clean-dist.mjs packages/cli && node scripts/run-tsc.mjs packages/cli",
    "install:mcp": "node scripts/npm-install-prefix.mjs packages/mcp --no-fund --no-audit",
    "build:mcp": "npm run install:mcp && node scripts/clean-dist.mjs packages/mcp && node scripts/run-tsc.mjs packages/mcp",
    "build:packages": "node scripts/clean-dist.mjs packages/state-core && node scripts/run-tsc.mjs packages/state-core && node scripts/clean-dist.mjs packages/mcp && node scripts/run-tsc.mjs packages/mcp && node scripts/clean-dist.mjs packages/cli && node scripts/run-tsc.mjs packages/cli",
    "compile": "node scripts/ensure-dev-deps.mjs && npm run version:sync && npm run build:runtime && npm run build:state-core && node scripts/materialize-deps-for-vsix.mjs && node scripts/ensure-dev-deps.mjs && npm run build:cli && npm run build:mcp && node scripts/run-tsc.mjs .",
    "test": "npm run build:state-core && npm run test:v3-core --prefix packages/state-core",
    "test:v3-core": "npm run test:v3-core --prefix packages/state-core",
    "publish:npm": "npm run compile && node scripts/publish-npm.mjs",
    "publish:npm:dry-run": "npm run compile && node scripts/publish-npm.mjs --dry-run",
    "postversion": "node scripts/sync-version.mjs",
    "watch": "node scripts/ensure-dev-deps.mjs && node scripts/run-tsc.mjs . -watch"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@contora/runtime": "file:.vscode-pack/contora-runtime-1.2.6.tgz",
    "@contora/state-core": "file:.vscode-pack/contora-state-core-1.2.6.tgz",
    "simple-git": "^3.22.0"
  }
}
